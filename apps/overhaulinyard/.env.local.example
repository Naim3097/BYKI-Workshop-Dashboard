# ── Overhaul In Yard — environment ──────────────────────────────────────────
# Copy to .env.local and fill in. See docs/ADDING-A-WORKSHOP.md.

# This workshop's identity (must match the workshops row id/slug in Supabase).
NEXT_PUBLIC_WORKSHOP_ID=a0000000-0000-4000-8000-000000000001
NEXT_PUBLIC_WORKSHOP_SLUG=overhaulinyard

# Supabase (shared project for all workshops).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LeanX payments. Leave PAYMENTS_MODE=mock (built-in /pay/[ref] simulator) until
# the workshop's real credentials are ready, then set PAYMENTS_MODE=live.
PAYMENTS_MODE=mock
LEANX_AUTH_TOKEN=
# Per-workshop collection UUID. Env wins; otherwise workshops.leanx_collection_uuid.
LEANX_COLLECTION_UUID=
LEANX_API_HOST=https://api.leanx.io
