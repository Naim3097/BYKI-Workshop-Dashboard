# Copy this file to .env.local and fill values when available.

# Payment mode: "mock" runs the built-in simulator (no credentials needed).
# Switch to "live" once the LeanX collection UUID is provided.
PAYMENTS_MODE=mock

# LeanX credentials (provided by client later)
LEANX_AUTH_TOKEN=
LEANX_COLLECTION_UUID=
LEANX_API_HOST=https://api.leanx.io

# Public base URL of this deployment (used to build redirect/callback URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Owner area access (simple gate for the mockup; replaced by Supabase Auth later)
OWNER_ACCESS_CODE=mna-owner

# Supabase (left blank for the mockup; the file-backed store is used until these are set)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
